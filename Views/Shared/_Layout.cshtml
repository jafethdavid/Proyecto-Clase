<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>SISTEMA DE VENTAS GRUPO 2</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>

        /* ESPACIO DEBAJO DEL NAVBAR */
        .fondo-sistema {
            margin-top: 30px;
        }

        /* LOGO SIN DISTORSION */
        .navbar-brand img {
            height: 50px;
            width: auto;
            object-fit: contain;
        }

        /* MEJORA VISUAL DEL CONTENIDO */
        .contenido-principal {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4">

        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/img/Logo2.png" class="me-2">
                Mercadito UPH
            </a>

            <!-- BOTONES -->
            <div class="ms-auto d-flex gap-3">

                <a class="btn btn-outline-light" href="/Producto">
                    <i class="bi bi-box-seam me-1"></i>
                    Productos
                </a>

                <a class="btn btn-outline-light" href="/Venta/Create">
                    <i class="bi bi-cart-check me-1"></i>
                    Ventas
                </a>

                <div class="dropdown">

                    <button class="btn btn-outline-light dropdown-toggle"
                            data-bs-toggle="dropdown">

                        <i class="bi bi-bar-chart-line me-1"></i>
                        Reportes

                    </button>

                    <ul class="dropdown-menu">

                        <li>
                            <a class="dropdown-item" href="/Reporte/Productos">
                                <i class="bi bi-box-seam me-2"></i>
                                Reporte de Productos
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/Reporte/Lotes">
                                <i class="bi bi-collection me-2"></i>
                                Lotes por Producto
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/Reporte/Movimientos">
                                <i class="bi bi-arrow-left-right me-2"></i>
                                Movimientos de Inventario
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/Reporte/Ventas">
                                <i class="bi bi-cash-coin me-2"></i>
                                Reporte de Ventas
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </div>

    </nav>


    <div class="fondo-sistema">

        <div class="container">

            <div class="contenido-principal">

                @RenderBody()

            </div>

        </div>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>