@{
    ViewData["Title"] = "Registrar Venta";

    var mensajeExito = TempData["Exito"] as string;
    var mensajeError = TempData["Error"] as string;
}

<h2 class="mb-4 text-center">
    <i class="bi bi-cart-check"></i> Sistema de Ventas
</h2>

@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div id="alertaVenta" class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>
        @mensajeExito
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        @mensajeError
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@using (Html.BeginForm("Create", "Venta", FormMethod.Post))
{

    <div class="card shadow">
        <div class="card-body">

            <div id="alertaStock"></div>

            <div class="row mb-3">

                <div class="col-md-6">

                    <label><i class="bi bi-box-seam me-1"></i> Producto</label>

                    <select id="productoSelect" class="form-control">

                        @foreach (var p in ViewBag.Productos)
                        {
                            <option value="@p.IdProducto"
                                    data-precio="@p.PrecioVenta"
                                    data-stock="@p.StockTotal()">

                                @p.NombreProducto (Stock: @p.StockTotal())

                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <label><i class="bi bi-123 me-1"></i> Cantidad</label>

                    <input type="number"
                           id="cantidad"
                           class="form-control"
                           value="1"
                           min="1">

                </div>

                <div class="col-md-3 d-flex align-items-end">

                    <button type="button"
                            class="btn btn-primary w-100"
                            onclick="agregarProducto()">

                        <i class="bi bi-plus-circle"></i> Agregar

                    </button>

                </div>

            </div>

            <hr>

            <table class="table table-bordered text-center" id="tablaVenta">

                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-box"></i> Producto</th>
                        <th><i class="bi bi-123"></i> Cantidad</th>
                        <th><i class="bi bi-currency-dollar"></i> Precio</th>
                        <th><i class="bi bi-calculator"></i> Subtotal</th>
                        <th><i class="bi bi-gear"></i> Acción</th>
                    </tr>
                </thead>

                <tbody></tbody>

            </table>

            <div class="row mt-3">

                <div class="col-md-6">
                    <a href="/Producto" class="btn btn-danger">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </a>
                </div>

                <div class="col-md-6 text-end">

                    <h4>
                        <i class="bi bi-cash-stack"></i> Total: L.
                        <span id="total">0</span>
                    </h4>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-cart-check"></i> Vender
                    </button>

                </div>

            </div>

        </div>
    </div>

}

<script src="~/js/ventas.js"></script>